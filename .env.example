NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=8787
HUAGE_CORS_ORIGIN=http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8787/api
VITE_BASE_PATH=/

# Current executable MVP adapter.
HUAGE_STORE=json
HUAGE_DATA_FILE=/absolute/path/huage-runtime.json
HUAGE_SOURCE_FILE_ADAPTER=local
HUAGE_SOURCE_FILE_DIR=/absolute/path/huage-source-files

# PostgreSQL target adapter readiness. Keep HUAGE_STORE=json until the adapter is implemented.
DATABASE_URL=postgres://huage:password@127.0.0.1:5432/huage_os

HUAGE_MAX_BODY_BYTES=15000000
HUAGE_MAX_SOURCE_FILE_BYTES=10000000

# Local debugging only; never enable this in production.
HUAGE_ALLOW_HEADER_AUTH=0

# Cloudflare Workers + D1 deployment.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=

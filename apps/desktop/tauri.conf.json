{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HUAGE Commercial OS",
  "version": "0.1.0",
  "identifier": "com.huage.commercial-os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HUAGE Commercial OS",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Business"
  }
}
